      },
      {
        "command": "dabbler.installOrchestratorHook.gemini",
        "title": "Install Orchestrator Hook (Gemini Code Assist)",
        "category": "Dabbler"
      },
      {
        "command": "dabbler.installOrchestratorHook.copilot",
        "title": "Install Orchestrator Hook (GitHub Copilot)",
        "category": "Dabbler"
