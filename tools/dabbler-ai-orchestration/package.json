{
  "name": "dabbler-ai-orchestration",
  "displayName": "Dabbler AI Orchestration",
  "description": "Project wizard, session-set explorer, cost dashboard, and adoption-bootstrap entry point for the Dabbler AI-led workflow.",
  "version": "0.22.0",
  "publisher": "DarndestDabbler",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "AI",
    "SCM Providers"
  ],
  "keywords": [
    "ai",
    "workflow",
    "session",
    "claude",
    "orchestration",
    "dabbler",
    "adoption",
    "bootstrap",
    "onboarding"
  ],
  "icon": "media/darndest-dabbler-icon.png",
  "galleryBanner": {
    "color": "#5DADE2",
    "theme": "dark"
  },
  "homepage": "https://darndestdabbler.org",
  "bugs": {
    "url": "https://github.com/darndestdabbler/dabbler-ai-orchestration/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/darndestdabbler/dabbler-ai-orchestration.git"
  },
  "license": "MIT",
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dabblerSessionSetsContainer",
          "title": "Dabbler AI Orchestration",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "dabblerSessionSetsContainer": [
        {
          "type": "webview",
          "id": "dabblerSessionSets",
          "name": "Session Sets",
          "contextualTitle": "Dabbler AI Orchestration"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "dabblerSessionSets",
        "when": "dabblerSessionSets.scanState == ready",
        "contents": "No session sets in this workspace yet.\n\nThe quickest way to get started is to copy the adoption bootstrap prompt and paste it into a fresh AI chat (Claude Code, Gemini Code Assist, or any GPT-based tool). The AI will fetch the canonical setup instructions, talk you through a budget-threshold dialog, and present a numbered checklist of every intended write for batch approval before executing — no per-write prompts.\n[Copy adoption bootstrap prompt](command:dabbler.copyAdoptionBootstrapPrompt)\nPrefer a guided wizard? The Get Started panel offers the same starting points without leaving VS Code.\n[Open Get Started](command:dabbler.getStarted)\nMore on the workflow: [Dabbler AI Orchestration on GitHub](https://github.com/darndestdabbler/dabbler-ai-orchestration#readme)"
      }
    ],
    "commands": [
      {
        "command": "dabblerSessionSets.refresh",
        "title": "Refresh Session Sets",
        "category": "Dabbler",
        "icon": "$(refresh)"
      },
      {
        "command": "dabblerSessionSets.openSpec",
        "title": "Open Spec",
        "category": "Dabbler"
      },
      {
        "command": "dabblerSessionSets.openActivityLog",
        "title": "Open Activity Log",
        "category": "Dabbler"
      },
      {
        "command": "dabblerSessionSets.openChangeLog",
        "title": "Open Change Log",
        "category": "Dabbler"
      },
      {
        "command": "dabblerSessionSets.openUatChecklist",
        "title": "Open UAT Checklist",
        "category": "Dabbler"
      },
      {
        "command": "dabblerSessionSets.revealPlaywrightTests",
        "title": "Reveal Playwright Tests for This Set",
        "category": "Dabbler"
      },
      {
        "command": "dabblerSessionSets.openSessionState",
        "title": "Open Session State",
        "category": "Dabbler"
      },
      {
        "command": "dabblerSessionSets.openFolder",
        "title": "Reveal Folder",
        "category": "Dabbler"
      },
      {
        "command": "dabblerSessionSets.copyStartCommand.default",
        "title": "Copy: Start next session",
        "category": "Dabbler"
      },
      {
        "command": "dabblerSessionSets.copyStartCommand.parallel",
        "title": "Copy: Start next parallel session",
        "category": "Dabbler"
      },
      {
        "command": "dabblerSessionSets.copySlug",
        "title": "Copy: Slug only",
        "category": "Dabbler"
      },
      {
        "command": "dabbler.copySpecReviewPrompt",
        "title": "Copy: Spec-review prompt",
        "category": "Dabbler"
      },
      {
        "command": "dabbler.copySessionAccomplishmentsPrompt",
        "title": "Copy: Session-accomplishments review prompt",
        "category": "Dabbler"
      },
      {
        "command": "dabbler.copySetAccomplishmentsPrompt",
        "title": "Copy: Set-accomplishments review prompt",
        "category": "Dabbler"
      },
      {
        "command": "dabbler.copyStartNextSessionPrompt",
        "title": "Copy: Start the next session",
        "category": "Dabbler"
      },
      {
        "command": "dabbler.openExternalVerificationDoc",
        "title": "Open External Verification Document",
        "category": "Dabbler"
      },
      {
        "command": "dabbler.getStarted",
        "title": "Get Started",
        "category": "Dabbler",
        "icon": "$(star)"
      },
      {
        "command": "dabbler.copyAdoptionBootstrapPrompt",
        "title": "Copy adoption bootstrap prompt",
        "category": "Dabbler"
      },
      {
        "command": "dabbler.setupNewProject",
        "title": "Set Up New Project",
        "category": "Dabbler",
        "icon": "$(add)"
      },
      {
        "command": "dabbler.importPlan",
        "title": "Import Project Plan",
        "category": "Dabbler"
      },
      {
        "command": "dabbler.generateSessionSetPrompt",
        "title": "Generate Session-Set Prompt",
        "category": "Dabbler"
      },
      {
        "command": "dabbler.troubleshoot",
        "title": "Troubleshoot",
        "category": "Dabbler",
        "icon": "$(debug)"
      },
      {
        "command": "dabbler.showCostDashboard",
        "title": "Show Cost Dashboard",
        "category": "Dabbler",
        "icon": "$(graph)"
      },
      {
        "command": "dabblerSessionSets.cancel",
        "title": "Cancel Session Set",
