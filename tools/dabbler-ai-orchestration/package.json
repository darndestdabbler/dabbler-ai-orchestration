        "icon": "$(sync)"
      },
      {
        "command": "dabbler.openConfigEditor",
        "title": "Open Dabbler Config Editor",
        "category": "Dabbler",
        "icon": "$(settings-gear)"
      },
      {
        "command": "dabbler.flagDecisionForReview",
        "title": "Flag Decision for Cross-Provider Review",
